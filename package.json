{
  "name": "kunapot.com",
  "private": true,
  "description": "Just another blog",
  "version": "0.1.1",
  "author": "aofleejay",
  "scripts": {
    "build": "gatsby build",
    "dev": "gatsby develop",
    "serve": "gatsby serve",
    "format": "prettier --ignore-path .gitignore \"**/*.+(js|json|ts|tsx)\" --write",
    "lint": "eslint src gatsby-*.js",
    "test": "jest --passWithNoTests --forceExit",
    "test:watch": "jest --watch --passWithNoTests",
    "coveralls": "jest --coverage && cat ./coverage/lcov.info | coveralls",
    "deploy": "gatsby build && gh-pages -d public",
    "blog:create": "bun src/scripts/create-blog.ts",
    "image:resize": "bun src/scripts/resize-image.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@deckdeckgo/highlight-code": "^4.4.0",
    "@fontsource/ibm-plex-sans-thai": "^5.2.8",
    "@fontsource/quicksand": "^5.2.10",
    "disqus-react": "^1.1.7",
    "gatsby": "^5.16.1",
    "gatsby-plugin-dark-mode": "^1.1.2",
    "gatsby-plugin-google-gtag": "^5.16.0",
    "gatsby-plugin-image": "^3.16.0",
    "gatsby-plugin-manifest": "^5.16.0",
    "gatsby-plugin-offline": "^6.16.0",
    "gatsby-plugin-sharp": "^5.16.0",
    "gatsby-plugin-sitemap": "^6.16.0",
    "gatsby-plugin-typescript": "^5.16.0",
    "gatsby-remark-embed-video": "^3.2.1",
    "gatsby-remark-highlight-code": "^3.3.0",
    "gatsby-remark-images": "^7.16.0",
    "gatsby-source-filesystem": "^5.16.0",
    "gatsby-transformer-remark": "^6.16.0",
    "gatsby-transformer-sharp": "^5.16.0",
    "lodash.get": "^4.4.2",
    "lodash.kebabcase": "^4.1.1",
    "postcss": "^8.5.15",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-icons": "^5.6.0"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@tailwindcss/postcss": "^4.3.1",
    "@tailwindcss/typography": "^0.5.20",
    "@testing-library/react": "^16.3.2",
    "@types/inquirer": "^9.0.10",
    "@types/jest": "^30.0.0",
    "@types/lodash": "^4.17.24",
    "@types/lodash.kebabcase": "^4.1.9",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/react-test-renderer": "^19.1.0",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "babel-jest": "^30.4.1",
    "babel-preset-gatsby": "^3.16.0",
    "coveralls": "^3.1.1",
    "dotenv": "^17.4.2",
    "eslint": "9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "gatsby-plugin-postcss": "^6.16.0",
    "gatsby-plugin-webpack-bundle-analyser-v2": "^1.1.32",
    "gh-pages": "^6.3.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "identity-obj-proxy": "^3.0.0",
    "inquirer": "^14.0.2",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "30",
    "lodash": "^4.18.1",
    "prettier": "3.8.4",
    "pretty-quick": "^4.2.2",
    "react-test-renderer": "^19.2.7",
    "sharp": "^0.35.2",
    "tailwindcss": "^4.3.1",
    "ts-jest": "^29.4.11",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1"
  },
  "license": "MIT",
  "homepage": "https://kunapot.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/aofleejay/kunapot.com"
  },
  "bugs": {
    "url": "https://github.com/aofleejay/kunapot.com/issues"
  },
  "packageManager": "bun@1.3.14",
  "trustedDependencies": [
    "sharp",
    "gatsby",
    "gatsby-plugin-sharp",
    "gatsby-cli"
  ]
}
